# ─── Mock mode (no backend) ───
# VITE_USE_MOCK=true
# VITE_API_URL=

# ─── Backend integration (auth server on port 3000) ───
VITE_USE_MOCK=false
VITE_API_URL=http://localhost:3000/api

# Backend auth routes: POST /api/auth/login, /register, GET /api/auth/profile
# Session uses httpOnly cookie — frontend sends credentials: 'include'
